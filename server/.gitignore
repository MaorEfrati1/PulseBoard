# ============================================================
#  SERVER .gitignore  (Node.js / Express / TypeScript / Prisma)
# ============================================================

# ── Dependencies ────────────────────────────────────────────
node_modules/

# ── Build Output ────────────────────────────────────────────
dist/
build/
out/

# ── TypeScript ──────────────────────────────────────────────
*.tsbuildinfo
tsconfig.tsbuildinfo

# ── Environment & Secrets ───────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.cert
serviceAccountKey.json
firebase-adminsdk*.json

# ── Prisma ──────────────────────────────────────────────────
prisma/migrations/**/migration_lock.toml

# ── Logs (Winston + npm) ────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Redis / DB local dumps ──────────────────────────────────
dump.rdb
*.sql.gz
*.pgdump

# ── Testing ─────────────────────────────────────────────────
coverage/
.nyc_output/

# ── OS ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Misc ────────────────────────────────────────────────────
.cache/
*.bak
*.tmp